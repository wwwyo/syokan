{
  "name": "@syokan/app",
  "version": "0.0.4",
  "description": "syokan — LLMs summon rich UI: post a JSON tree and predefined React components render an ephemeral view.",
  "type": "module",
  "private": true,
  "exports": {
    "./render": "./src/Render.tsx",
    "./schema": "./src/schema/index.ts",
    "./components/CodeSnippet": "./src/components/CodeSnippet/index.tsx",
    "./viewState": "./src/lib/viewState.tsx",
    "./styles.css": "./src/styles.css"
  },
  "imports": {
    "#lib/*": "./src/lib/*",
    "#components/*": "./src/components/*",
    "#hooks/*": "./src/hooks/*"
  },
  "scripts": {
    "dev": "portless run --name syokan --app-port 5273 env XDG_CONFIG_HOME=$PWD/../../.syokan-dev/config XDG_DATA_HOME=$PWD/../../.syokan-dev/data XDG_STATE_HOME=$PWD/../../.syokan-dev/state SYOKAN_SHARE_API=http://localhost:8787 bun --hot server/index.ts",
    "compile": "bun build.ts",
    "compile:all": "bun build.ts --release",
    "release": "bun scripts/release.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@pierre/diffs": "1.2.5",
    "@tanstack/react-router": "1.170.15",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "hono": "4.12.27",
    "lucide-react": "1.14.0",
    "mermaid": "11.15.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-resizable-panels": "4.11.2",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "10.4.1",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/addon-themes": "10.4.1",
    "@storybook/react-vite": "10.4.1",
    "@tailwindcss/vite": "4.3.0",
    "@types/bun": "1.3.13",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "bun-plugin-tailwind": "0.1.2",
    "portless": "0.12.0",
    "storybook": "10.4.1",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
