{
	"$schema": "../../node_modules/wrangler/config-schema.json",
	"name": "syokan-share",
	"main": "worker.ts",
	"compatibility_date": "2026-06-01",
	"routes": [
		{
			"pattern": "syokan.dev",
			"custom_domain": true
		}
	],
	"kv_namespaces": [
		{
			"binding": "SHARES",
			"id": "febb64d439804e40a07fa22423f41495"
		}
	],
	"assets": {
		"directory": "./viewer/dist",
		"binding": "ASSETS",
		"run_worker_first": true
	}
}