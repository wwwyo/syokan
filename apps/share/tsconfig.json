{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // share 自身の import は "syokan/*" (package exports) を使う。この paths は
    // 取り込まれる syokan 側 source の内部 import ("@/lib/...") を tsc が解決するためだけに残す
    // (tsc は compile 対象 project の paths で全ファイルを解決する)
    "paths": {
      "@/*": ["../syokan/src/*"]
    }
  },
  "include": [
    "types.ts",
    "worker.ts",
    "worker.test.ts",
    "build.ts",
    "csp.generated.ts",
    "viewer"
  ],
  "exclude": ["node_modules", "viewer/dist"]
}
