{
  "name": "syokan",
  "version": "0.0.3",
  "description": "syokan — LLMs summon rich UI: post a JSON tree and predefined React components render an ephemeral view.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "portless run --app-port 5273 env XDG_CONFIG_HOME=$PWD/.syokan-dev/config XDG_DATA_HOME=$PWD/.syokan-dev/data XDG_STATE_HOME=$PWD/.syokan-dev/state bun --hot server/index.ts",
    "compile": "bun build.ts",
    "compile:all": "bun build.ts --release",
    "release": "bun scripts/release.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "1.4.1",
    "@pierre/diffs": "1.2.5",
    "@tanstack/react-router": "1.170.15",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.14.0",
    "mermaid": "11.15.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "10.1.0",
    "react-resizable-panels": "4.11.2",
    "remark-gfm": "4.0.1",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "10.4.1",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/addon-themes": "10.4.1",
    "@storybook/react-vite": "10.4.1",
    "@tailwindcss/vite": "4.3.0",
    "@types/bun": "1.3.13",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "bun-plugin-tailwind": "0.1.2",
    "portless": "0.12.0",
    "storybook": "10.4.1",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
