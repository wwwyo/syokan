node_modules/

# Build output
dist/
build/
storybook-static/

# Test / coverage
coverage/

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Ephemeral state (syokan は data を持たない設計、念のため除外)
.syokan-state/
data/
# dev server のローカル XDG base (dev script が XDG_*_HOME=$PWD/.syokan-dev/{config,data,state})
.syokan-dev/
# wrangler dev のローカル状態 (miniflare の KV/Cache = sqlite, bundle 一時ファイル)。本番とは無関係の再生成物
.wrangler/

# TypeScript
*.tsbuildinfo

# Installed (third-party) agent skills — vendored/symlinked, 他者のコンテンツを publish しない
.agents/skills/
.claude/skills/
.codex/skills/
